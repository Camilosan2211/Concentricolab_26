/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(81,112,255,.35); border-radius: 4px; }

/* Progress bar */
#pb {
  position: fixed; top: 0; left: 0; height: 2px; width: 0%;
  background: linear-gradient(90deg,#5170FF,#41EAFF,#FF6D4D);
  z-index: 9999; pointer-events: none; border-radius: 0 2px 2px 0;
  transition: width .08s linear;
}

/* Custom cursor — theme via CSS variables */
.cur-dot {
  position: fixed; pointer-events: none; z-index: 10000;
  width: 6px; height: 6px; border-radius: 50%; background: var(--cursor-dot);
  transform: translate(-50%,-50%); opacity: 0; will-change: left,top;
  transition: opacity .3s, transform .15s, background .25s;
}
.cur-ring {
  position: fixed; pointer-events: none; z-index: 9999;
  width: 30px; height: 30px; border-radius: 50%;
  border: 1.5px solid var(--cursor-ring);
  transform: translate(-50%,-50%); opacity: 0; will-change: left,top;
  transition: opacity .3s,
    width .2s cubic-bezier(.34,1.56,.64,1), height .2s cubic-bezier(.34,1.56,.64,1),
    border-radius .2s, border-color .25s;
}
.cur-ring.hov { width: 42px; height: 42px; border-color: var(--cursor-ring-hov); }
.cur-ring.lnk { border-radius: 7px; }

@media (pointer:coarse) { .cur-dot,.cur-ring { display:none; } }

/* Global premium film grain (very subtle) */
.film-grain-overlay {
  position: fixed;
  inset: -120%;
  pointer-events: none;
  z-index: 2;
  opacity: 0.024;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,.18) 0.6px, transparent 1.4px),
    radial-gradient(circle at 70% 60%, rgba(255,255,255,.14) 0.8px, transparent 1.6px),
    radial-gradient(circle at 40% 80%, rgba(255,255,255,.12) 0.5px, transparent 1.2px);
  background-size: 160px 160px, 210px 210px, 130px 130px;
  mix-blend-mode: soft-light;
  animation: filmGrainShift 9s steps(8) infinite;
}
html.light .film-grain-overlay {
  opacity: 0.02;
  mix-blend-mode: multiply;
}
@keyframes filmGrainShift {
  0% { transform: translate3d(0, 0, 0); }
  25% { transform: translate3d(-2.2%, 1.8%, 0); }
  50% { transform: translate3d(1.6%, -1.2%, 0); }
  75% { transform: translate3d(-1.4%, -1.8%, 0); }
  100% { transform: translate3d(0, 0, 0); }
}

