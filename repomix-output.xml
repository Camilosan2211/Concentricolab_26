html.light .hero-vignette {
  background:
    radial-gradient(ellipse 68% 52% at 50% 45%, rgba(255,255,255,0.35) 0%, transparent 62%),
    radial-gradient(ellipse 120% 90% at 50% 50%, transparent 46%, rgba(5,10,30,0.09) 100%);
}
.hero-brand-aurora {
  position: absolute;
  inset: -20% -10% auto -10%;
  height: 62%;
  pointer-events: none;
  z-index: 1;
  background:
    radial-gradient(ellipse at 22% 45%, rgba(81,112,255,0.2) 0%, transparent 58%),
    radial-gradient(ellipse at 82% 42%, rgba(255,109,77,0.16) 0%, transparent 56%),
    radial-gradient(ellipse at 52% 85%, rgba(130,138,255,0.13) 0%, transparent 60%);
  filter: blur(46px);
  opacity: 0.62;
  animation: auroraDrift 14s ease-in-out infinite alternate;
}
.hero-brand-aurora-2 {
  inset: auto -8% -22% -8%;
  height: 56%;
  opacity: 0.46;
  filter: blur(56px);
  animation-duration: 18s;
  animation-direction: alternate-reverse;
}
html.light .hero-brand-aurora {
  opacity: 0.44;
  filter: blur(54px);
}
html.light .hero-brand-aurora-2 {
  opacity: 0.34;
}
@keyframes auroraDrift {
  0% { transform: translate3d(-1.2%, 0.6%, 0) scale(1); }
  50% { transform: translate3d(1.4%, -1%, 0) scale(1.04); }
  100% { transform: translate3d(-0.8%, 1.1%, 0) scale(1.02); }
}
.hero-blur-layer {
  position: absolute;
  width: 36vw;
  height: 36vw;
  min-width: 260px;
  min-height: 260px;
  max-width: 520px;
  max-height: 520px;
  left: -8%;
  top: 22%;
  border-radius: 999px;
  pointer-events: none;
  z-index: 1;
  filter: blur(92px);
  opacity: 0.14;
  background: radial-gradient(circle, rgba(81,112,255,0.58) 0%, rgba(81,112,255,0) 70%);
  transition: transform 0.55s cubic-bezier(.22,1,.36,1);
}
.hero-blur-layer-2 {
  left: auto;
  right: -10%;
  top: 12%;
  opacity: 0.12;
  background: radial-gradient(circle, rgba(255,109,77,0.5) 0%, rgba(255,109,77,0) 72%);
}
.hero-blur-layer-3 {
  left: 28%;
  top: auto;
  bottom: -22%;
  opacity: 0.08;
  background: radial-gradient(circle, rgba(130,138,255,0.5) 0%, rgba(130,138,255,0) 72%);
}
html.light .hero-blur-layer { opacity: 0.12; }
html.light .hero-blur-layer-2 { opacity: 0.1; }
html.light .hero-blur-layer-3 { opacity: 0.07; }
.hero-motion-switch {
  border-color: rgba(255,255,255,.14);
}
html.light .hero-motion-switch {
  border-color: rgba(10,10,24,.08);
}
.hero-mode-dynamic .hero-brand-aurora {
  opacity: 0.76;
  animation-duration: 8s;
}
.hero-mode-dynamic .hero-brand-aurora-2 {
  opacity: 0.56;
  animation-duration: 10s;
}
.hero-mode-dynamic .hero-blur-layer {
  opacity: 0.2;
  transition-duration: 0.35s;
}
.hero-mode-luxury .hero-brand-aurora {
  opacity: 0.56;
  animation-duration: 16s;
}

/* Contenedor raíz — ocupa todo el hero */
.hero-grid-root {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

/* ---- Grid perspectiva ---- */
.hero-grid-perspective {
  position: absolute;
  bottom: 0;
  left: -10%;
  right: -10%;
  height: 58%;
  perspective: 420px;
  perspective-origin: 50% 0%;
}

.hero-grid-lines {
  position: absolute;
  inset: 0;
  background-image:
    /* líneas horizontales */
    repeating-linear-gradient(
      0deg,
      rgba(81, 112, 255, 0.10) 0px,
      rgba(81, 112, 255, 0.10) 1px,
      transparent 1px,
      transparent 48px
    ),
    /* líneas verticales */
    repeating-linear-gradient(
      90deg,
      rgba(81, 112, 255, 0.08) 0px,
      rgba(81, 112, 255, 0.08) 1px,
      transparent 1px,
      transparent 72px
    );
  transform: rotateX(52deg) scaleY(1.8);
  transform-origin: 50% 100%;
  -webkit-mask-image: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(0,0,0,0.6) 30%,
    rgba(0,0,0,0.85) 65%,
    transparent 100%
  );
  mask-image: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(0,0,0,0.6) 30%,
    rgba(0,0,0,0.85) 65%,
    transparent 100%
  );
  animation: gridPulse 6s ease-in-out infinite;
  will-change: opacity;
  display: none; /* Quitado según requerimiento */
}

@keyframes gridPulse {
  0%, 100% { opacity: 0.6; }
  50%       { opacity: 1.0; }
}

/* ---- Línea de scan ---- */
.hero-scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1.5px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(65, 234, 255, 0.0) 5%,
    rgba(65, 234, 255, 0.55) 35%,
    rgba(65, 234, 255, 0.85) 50%,
    rgba(65, 234, 255, 0.55) 65%,
    rgba(65, 234, 255, 0.0) 95%,
    transparent 100%
  );
  animation: scanDown 9s linear infinite;
  will-change: top;
  filter: blur(0.5px);
  display: none; /* Quitado según requerimiento */
}

@keyframes scanDown {
  0%   { top: 15%; opacity: 0; }
  8%   { opacity: 1; }
  88%  { opacity: 0.8; }
  100% { top: 82%; opacity: 0; }
}

/* ---- Glows laterales ---- */
.hero-side-glow {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 22vw;
  min-width: 140px;
  max-width: 280px;
  pointer-events: none;
}

.hero-side-glow-left {
  left: 0;
  background: radial-gradient(
    ellipse 100% 60% at 0% 42%,
    rgba(81, 112, 255, 0.22) 0%,
    rgba(81, 112, 255, 0.10) 40%,
    transparent 75%
  );
  animation: glowBreathLeft 7s ease-in-out infinite;
}

.hero-side-glow-right {
  right: 0;
  background: radial-gradient(
    ellipse 100% 60% at 100% 52%,
    rgba(255, 109, 77, 0.20) 0%,
    rgba(255, 109, 77, 0.09) 40%,
    transparent 75%
  );
  animation: glowBreathRight 8.5s ease-in-out infinite;
}

@keyframes glowBreathLeft {
  0%, 100% { opacity: 0.7; transform: scaleY(1);    }
  50%       { opacity: 1.0; transform: scaleY(1.06); }
}

@keyframes glowBreathRight {
  0%, 100% { opacity: 0.6; transform: scaleY(1);    }
  50%       { opacity: 1.0; transform: scaleY(1.08); }
}

/* ---- Orbe central de profundidad ---- */
.hero-center-orb {
  position: absolute;
  left: 50%;
  top: 54%;
  translate: -50% -50%;
  width: 55vw;
  max-width: 700px;
  aspect-ratio: 1;
  background: radial-gradient(
    circle,
    rgba(81, 112, 255, 0.07) 0%,
    rgba(81, 112, 255, 0.03) 45%,
    transparent 72%
  );
  animation: orbPulse 11s ease-in-out infinite;
}

@keyframes orbPulse {
  0%, 100% { opacity: 0.6; transform: scale(1);    }
  50%       { opacity: 1.0; transform: scale(1.05); }
}

/* Modo light: reducir intensidad */
html.light .hero-grid-lines       { opacity: 0.25; }
html.light .hero-scan-line        { opacity: 0.18; }
html.light .hero-side-glow-left   { opacity: 0.30; background: radial-gradient(ellipse 100% 60% at 0% 42%, rgba(81,112,255,0.18) 0%, rgba(81,112,255,0.08) 40%, transparent 75%); }
html.light .hero-side-glow-right  { opacity: 0.28; background: radial-gradient(ellipse 100% 60% at 100% 52%, rgba(255,109,77,0.18) 0%, rgba(255,109,77,0.09) 40%, transparent 75%); }
html.light .hero-center-orb       { opacity: 0.24; background: radial-gradient(circle, rgba(81,112,255,0.10) 0%, rgba(81,112,255,0.02) 45%, transparent 72%); }

/* Hero shimmer premium compartido (viewport-locked) */
.hero-shimmer {
  color: var(--coral);
  text-shadow: none;
}
@supports (-webkit-background-clip: text) or (background-clip: text) {
  .hero-shimmer {
    background: linear-gradient(
      90deg,
      #ff6d4d 0%,
      #ff6d4d 10%,
      #ffbe9e 18%,
      #828aff 28%,
      #5170ff 40%,
      #5170ff 52%,
      #aab2ff 62%,
      #ff6d4d 72%,
      #ff6d4d 82%,
      #ffbe9e 90%,
      #828aff 100%
    );
    background-size: 340% 100%;
    background-attachment: local;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 0 transparent;
    color: transparent;
    animation: heroShimmer 5s ease-in-out infinite alternate;
    will-change: background-position;
  }
  .hero-mode-dynamic .hero-shimmer {
    animation-duration: 2.6s;
    animation-timing-function: ease-in-out;
  }
}
@keyframes heroShimmer {
  0%   { background-position: 90% center; }
  100% { background-position: 10% center; }
}

/* Footer: micro resplandor al hover en la marca */
@keyframes footer-brand-pulse {
  0%, 100% {
    text-shadow: 0 0 10px rgba(81, 112, 255, 0.35), 0 0 20px rgba(255, 109, 77, 0.2);
  }
  50% {
    text-shadow: 0 0 14px rgba(255, 109, 77, 0.45), 0 0 26px rgba(81, 112, 255, 0.25);
  }
}
.footer-brand-glow {
  transition: color 0.25s ease;
}
.footer-brand-glow:hover {
  animation: footer-brand-pulse 1.8s ease-in-out infinite;
}
html.light .footer-brand-glow:hover {
  animation: footer-brand-pulse 1.8s ease-in-out infinite;
}

/* Hex shape for avatars / circles */
.hex-clip {
  clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
}

