        <pointLight position={[-3, -2, 3]} color="#FF6D4D" intensity={0.62} />
        <pointLight position={[0, 3, -3]} color="#41EAFF" intensity={0.36} />
        <KineticSpheres darkMode={darkMode} count={180} />
        <FloatingAccent darkMode={darkMode} />
      </Canvas>
